<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Contact access for caller identification -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Phone state for call detection -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />

    <!-- SMS interception and auto-reply -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.SEND_SMS" />

    <!-- Background processing and scheduling -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".FocusGuardApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FocusGuard">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            CallScreeningService — Android 10+ allows call screening without being the default dialer.
            The system binds this service when an incoming call arrives. We can reject, send to
            voicemail, or allow each call based on our rules. No role grant required on API 29+.
        -->
        <service
            android:name=".service.FocusGuardCallScreeningService"
            android:exported="true"
            android:permission="android.permission.BIND_SCREENING_SERVICE">
            <intent-filter>
                <action android:name="android.telecom.CallScreeningService" />
            </intent-filter>
        </service>

        <!--
            NotificationListenerService — receives all posted notifications.
            We use this to cancel notification banners from blocked contacts in messaging apps.
            The user must grant access in Settings → Apps → Special app access → Notification access.
        -->
        <service
            android:name=".service.FocusGuardNotificationListenerService"
            android:exported="true"
            android:label="@string/notification_listener_label"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
            <meta-data
                android:name="android.service.notification.default_filter_types"
                android:value="conversations,alerting" />
        </service>

        <!-- Foreground service keeps the app alive on OEMs with aggressive battery killers -->
        <service
            android:name=".service.FocusGuardForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Restarts the foreground service after device reboot -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- HTC / Xiaomi quick-boot -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- Receives WorkManager / AlarmManager schedule trigger events -->
        <receiver
            android:name=".receiver.ScheduleAlarmReceiver"
            android:exported="false" />

        <!--
            Disable WorkManager's default auto-initializer so our Hilt-aware Configuration.Provider
            can control initialization instead. Without this, WorkManager initializes during
            content-provider startup — before Hilt has injected workerFactory — causing an
            UninitializedPropertyAccessException crash on every app launch.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
